# Production-окружение для docker-compose (ТЗ §35, §37, §41).
# Скопируйте в .env на VPS и заполните значения. .env в Git НЕ коммитится.
#
#   cp .env.production.example .env
#
# Сгенерировать сильные секреты (любая из команд):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
#   openssl rand -base64 36

# --- Приложение ---
APP_ENV=production
# ОБЯЗАТЕЛЬНО замените на случайное значение (см. команды выше):
APP_SECRET_KEY=CHANGE_ME_GENERATE_A_LONG_RANDOM_SECRET
# Базовый URL сайта. С TLS — https://<домен>:
APP_BASE_URL=https://example.com
APP_TIMEZONE=Europe/Berlin
# Разрешённые Host (через запятую), защита от Host-header injection. Обычно ваш домен:
APP_ALLOWED_HOSTS=example.com
# Secure у сессионной cookie: "" — авто (Secure в production).
# ВАЖНО: пока работаете по HTTP (домена/TLS ещё нет) — поставьте false, иначе вход и
# CSRF ломаются («Недействительный CSRF-токен»). После включения TLS верните "" (или true).
SESSION_COOKIE_SECURE=
# Движок PDF: auto | weasyprint | xhtml2pdf (в Docker доступен weasyprint).
PDF_ENGINE=auto

# --- PostgreSQL (единственный источник учётных данных БД) ---
# DATABASE_* в compose берутся из этих же значений — задавать пароль дважды не нужно.
POSTGRES_DB=rental
POSTGRES_USER=rental
# ОБЯЗАТЕЛЬНО замените на сильный пароль:
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# --- Приложение: воркеры за прокси ---
# Число воркеров uvicorn (ориентир: 2×CPU+1, для небольшого VPS достаточно 2–3).
WEB_CONCURRENCY=3

# --- Backup (ТЗ §36) ---
# Каталог хоста для резервных копий (вне рабочих volume). Смонтируется в /backups.
BACKUP_PATH=./backups
BACKUP_TIME=03:00
BACKUP_RETENTION_DAYS=14

# --- Nginx / TLS ---
# HTTP по умолчанию: ./nginx/app.conf. После выпуска сертификата переключите на TLS:
#   NGINX_CONF=./nginx/app-ssl.conf
NGINX_CONF=./nginx/app.conf
