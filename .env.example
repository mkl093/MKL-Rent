# Скопируйте этот файл в .env и заполните значения.
# .env в Git НЕ коммитится (ТЗ §37, §41.2).

# --- Приложение ---
APP_ENV=development
# Секрет для подписи сессионных cookie. Сгенерируйте: python -c "import secrets; print(secrets.token_urlsafe(48))"
APP_SECRET_KEY=change-me-in-production
APP_BASE_URL=http://localhost:8000
APP_TIMEZONE=Europe/Berlin

# --- База данных (части собираются в DATABASE_URL) ---
DATABASE_NAME=rental
DATABASE_USER=rental
DATABASE_PASSWORD=rental
DATABASE_HOST=localhost
DATABASE_PORT=5432
# Необязательный полный override (например, для быстрого локального смоука):
# DATABASE_URL=sqlite:///./dev.db

# --- Хранение файлов и backup ---
STORAGE_PATH=./storage
BACKUP_PATH=./backups
BACKUP_TIME=03:00
BACKUP_RETENTION_DAYS=14

# --- PostgreSQL (для docker-compose) ---
POSTGRES_DB=rental
POSTGRES_USER=rental
POSTGRES_PASSWORD=rental

# --- Тесты ---
# Тестовый PostgreSQL для integration-тестов (если не задан — integration пропускаются):
# DATABASE_URL_TEST=postgresql+psycopg://rental:rental@localhost:5432/rental_test
